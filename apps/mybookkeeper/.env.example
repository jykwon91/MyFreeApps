# Docker Compose environment variables
# Seed it (plus backend/.env.docker) on the VPS:
#   cd /srv/myfreeapps && PYTHONPATH=packages/shared-backend python3 -m platform_shared.infra.seed_env --app mybookkeeper

# PostgreSQL password (used by postgres container and connection strings)
DB_PASSWORD=change-me-to-a-strong-password

# Domain for Caddy TLS (defaults to localhost for local dev)
DOMAIN=localhost

# MinIO (self-hosted S3-compatible object storage) — see deploy/MINIO_SETUP.md
# Generate the KMS secret via: bash scripts/generate-minio-kms-key.sh
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_KMS_SECRET_KEY=
# Optional: override the console URL the MinIO browser redirects to.
# Leave blank to default to http://localhost:9001 (only reachable via SSH tunnel in prod).
MINIO_BROWSER_URL=
