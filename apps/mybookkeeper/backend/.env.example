DATABASE_URL=postgresql+asyncpg://user:password@localhost/mybookkeeper
SECRET_KEY=your-secret-key-min-32-chars
ENCRYPTION_KEY=your-encryption-key-min-32-chars
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_URI=https://yourdomain.com/integrations/gmail/callback
CORS_ORIGINS=["https://yourdomain.com"]
JWT_LIFETIME_SECONDS=86400
GMAIL_POLL_INTERVAL_MINUTES=15
MAX_UPLOADS_PER_USER_PER_DAY=50
MAX_UPLOAD_SIZE_BYTES=10485760
SENTRY_DSN=
POSTHOG_API_KEY=

# MinIO storage (self-hosted) — see deploy/MINIO_SETUP.md
# Internal endpoint: docker-network host the API uses for puts/gets/deletes.
MINIO_ENDPOINT=localhost:9000
# Public endpoint: hostname the browser hits for presigned URLs.
# Leave blank for local dev (single-endpoint mode). In prod, set to https://storage.<your-domain>.
MINIO_PUBLIC_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=mybookkeeper-files
MINIO_SECURE=false
PRESIGNED_URL_TTL_SECONDS=3600
EMAIL_FROM_ADDRESS=mybookkeeper6@gmail.com
EMAIL_FROM_NAME=MyBookkeeper
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mybookkeeper6@gmail.com
SMTP_PASSWORD=your-gmail-app-password
COST_ALERT_RECIPIENTS=
APP_URL=
# Set to true in dev/test to enable POST /test/promote-admin (never in production)
ALLOW_TEST_ADMIN_PROMOTION=false
# Set to false in local dev or CI to skip the HIBP compromised-password network check
HIBP_ENABLED=true

# KeyCheck screening provider (PR 3.3 — rentals Phase 3 redirect-only flow).
# Hosts who use a different KeyCheck tenant or want to point at a staging
# dashboard override this. Leave at the public dashboard for production.
KEYCHECK_DASHBOARD_URL=https://www.keycheck.com/dashboard

# ClamAV antivirus scan socket path (optional). When set, screening report
# uploads are scanned via the local ClamAV daemon. When unset, scanning is
# skipped with a WARNING log — operators wire this up in production.
CLAMAV_SOCKET_PATH=

# Override the screening report size cap (bytes). Defaults to 10 MB.
# MAX_SCREENING_REPORT_BYTES=10485760
