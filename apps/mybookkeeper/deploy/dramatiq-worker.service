[Unit]
Description=MyBookkeeper Dramatiq Worker
After=network.target postgresql.service

[Service]
User=deploy
WorkingDirectory=/srv/mybookkeeper/backend
EnvironmentFile=/srv/mybookkeeper/backend/.env
ExecStart=/srv/mybookkeeper/backend/.venv/bin/dramatiq app.workers.email_sync_worker
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
