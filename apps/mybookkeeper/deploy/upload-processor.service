[Unit]
Description=MyBookkeeper Upload Processor
After=network.target postgresql.service

[Service]
User=deploy
WorkingDirectory=/srv/mybookkeeper/backend
EnvironmentFile=/srv/mybookkeeper/backend/.env
ExecStart=/srv/mybookkeeper/backend/.venv/bin/python -m app.workers.upload_processor_worker
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
