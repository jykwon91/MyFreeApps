{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyGamingAssistant",
  "version": "0.0.1",
  "identifier": "org.myfreeapps.mygamingassistant",
  "build": {
    "beforeDevCommand": "npm --prefix ../../../.. --workspace=apps/mygamingassistant/frontend run dev -- --port 5176 --strictPort",
    "beforeBuildCommand": "npm --prefix ../../../.. --workspace=apps/mygamingassistant/frontend run build",
    "devUrl": "http://localhost:5176",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyGamingAssistant",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "MyGamingAssistant — lineup viewer for tactical FPS games",
    "longDescription": "MyGamingAssistant is a single-user lineup and utility viewer for tactical FPS games (Valorant, CS2). The desktop build wraps the web SPA with system webview for second-monitor use, and (in later releases) adds CS2 Game State Integration and minimap CV for live mode."
  }
}
