# Docker environment template — consumed by docker-compose.yml `env_file:` directive
# for the migrate and api services. Seed it (plus the compose-level .env) on the VPS:
#   cd /srv/myfreeapps && PYTHONPATH=packages/shared-backend python3 -m platform_shared.infra.seed_env --app mygamingassistant
#
# DATABASE_URL is set via docker-compose.yml `environment:` block — do NOT set it here.
# DB_PASSWORD lives in apps/mygamingassistant/.env (same dir as docker-compose.yml) — do NOT set it here.

# Deployment environment — controls the seed-user boot guard.
# Set to "production" in prod deployments; SEED_USER_* become REQUIRED.
# Leave as "development" or "test" for local/CI environments.
# Diverges from apps/myjobhunter: MGA opts out of Sentry (single-user
# app — see _SENTRY_EXEMPT in
# packages/shared-backend/tests/test_app_conformance.py).
ENVIRONMENT=production

# ============================================================================
# SERVE-ONLY MODE — the production shape for MGA.
# ============================================================================
# SERVE_ONLY=true makes MGA a PURE PUBLIC READ-ONLY lineup library with ZERO
# authentication. The operator authors lineups LOCALLY (full auth) and seeds
# prod via the import-lineups CLI; prod only ever serves the public library.
#
# When SERVE_ONLY=true:
#   - NO login / JWT / reset-password / verify / TOTP routes (they 404).
#   - NO auth-write routes (lineup/package/source/scheduler/admin mutations,
#     /users/me). Auth is ABSENT, not bypassed — fail closed.
#   - The operator seed user is NOT created; SEED_USER_* are NOT required.
#   - The Turnstile + email boot guards are SKIPPED; TURNSTILE_* and
#     EMAIL_*/SMTP_* are NOT required.
# So with SERVE_ONLY=true you can leave every variable in the
# "only when SERVE_ONLY=false" section below empty/unset.
#
# Set SERVE_ONLY=false (or unset) to run the FULL public-read / auth-write app
# (the local-dev shape): every auth + write route is mounted and the seed user
# + Turnstile + email boot guards behave as normal. In that case the
# "only when SERVE_ONLY=false" section below becomes REQUIRED in production.
#
# The matching frontend build flag is VITE_SERVE_ONLY (wired through
# docker-compose build.args → caddy.Dockerfile). Keep the two in sync: a
# prod with SERVE_ONLY=true on the backend but VITE_SERVE_ONLY unset on the
# frontend would render Sign-in CTAs that point at routes that return 404.
SERVE_ONLY=true

SECRET_KEY=change-me-to-random-64-chars
ENCRYPTION_KEY=change-me-to-random-64-chars

# Claude lineup classifier (PR 5+)
# ANTHROPIC_API_KEY: required when ENABLE_CLASSIFIER=true in production.
# Boot guard fires if key is missing + classifier enabled in production.
# Set ENABLE_CLASSIFIER=false to accept lineups without auto-classification.
ANTHROPIC_API_KEY=
# Model override — default claude-haiku-4-5-20251001 (cheapest vision model).
# Override with a Sonnet/Opus model for manual testing only.
CLAUDE_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# Set to false to disable auto-classification entirely. Lineups will land in
# pending_review with no suggestions; operator classifies manually.
ENABLE_CLASSIFIER=true

# ----------------------------------------------------------------------------
# ONLY WHEN SERVE_ONLY=false (local/dev full auth) — REQUIRED in prod full-auth.
# With SERVE_ONLY=true these are NOT used (no operator account exists) and the
# boot guard does NOT fire on empty values; leave them blank.
# ----------------------------------------------------------------------------
# Single-user seed — operator account.
# Both fields REQUIRED when ENVIRONMENT=production AND SERVE_ONLY=false; the
# boot guard fires if either is empty. Leave empty in dev/CI / serve_only — the
# seed is skipped with a log line.
#
# To generate SEED_USER_PASSWORD_HASH:
#   python -c "from passlib.context import CryptContext; \
#     ctx = CryptContext(schemes=['bcrypt']); \
#     print(ctx.hash('your-password'))"
SEED_USER_EMAIL=
SEED_USER_PASSWORD_HASH=

# Frontend / CORS
FRONTEND_URL=https://mygamingassistant.myfreeapps.org
CORS_ORIGINS=["https://mygamingassistant.myfreeapps.org"]

# JWT
JWT_LIFETIME_SECONDS=1800
LOG_LEVEL=INFO

# HIBP compromised-password check — leave true in prod
HIBP_ENABLED=true

# ----------------------------------------------------------------------------
# ONLY WHEN SERVE_ONLY=false — Cloudflare Turnstile CAPTCHA for /forgot-password.
# With SERVE_ONLY=true there is no auth (no forgot-password form), the Turnstile
# boot guard is SKIPPED, and these are NOT required. Leave blank.
# ----------------------------------------------------------------------------
# Registration is disabled (single-user app) so TURNSTILE_SITE_KEY
# is only needed for the forgot-password Turnstile widget. If Turnstile
# is not needed, leave these empty — require_turnstile is a no-op when
# TURNSTILE_SECRET_KEY is unset.
# Note: VITE_TURNSTILE_SITE_KEY in caddy.Dockerfile is passed regardless
# (the conformance test enforces that structural build-arg wiring); an empty
# value is fine when Turnstile is unused.
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# Account-level login lockout
LOCKOUT_THRESHOLD=5
LOCKOUT_AUTORESET_HOURS=24

# Per-IP login throttle
LOGIN_RATE_LIMIT_THRESHOLD=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# ----------------------------------------------------------------------------
# ONLY WHEN SERVE_ONLY=false — transactional email (verify / reset / login).
# With SERVE_ONLY=true there is no auth (no email is ever sent), the email boot
# guard is SKIPPED, and these are NOT required. Leave EMAIL_BACKEND=console (or
# anything) and SMTP_* blank.
# ----------------------------------------------------------------------------
# Email delivery
#
# When SERVE_ONLY=false, production MUST use EMAIL_BACKEND=smtp with valid
# SMTP_USER / SMTP_PASSWORD — the platform_shared boot guard crashes the
# lifespan if EMAIL_BACKEND=console in non-development environments.
#
# For local dev / CI, set EMAIL_BACKEND=console and leave SMTP_* empty.
EMAIL_BACKEND=smtp
EMAIL_FROM_NAME=MyGamingAssistant
EMAIL_FROM_ADDRESS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Object storage — Cloudflare R2 in production (S3-compatible).
# MGA prod serves a PUBLIC clip library; R2 gives free egress + an edge CDN
# (see memory/project_mga_prod_storage_r2.md). The minio-py client speaks S3,
# so these MINIO_* names point at R2 unchanged — it's an endpoint + creds swap.
#
#   MINIO_ENDPOINT        R2 S3 API endpoint, host[:port] form, NO scheme:
#                         <ACCOUNT_ID>.r2.cloudflarestorage.com
#                         (MINIO_SECURE=true selects https).
#   MINIO_ACCESS_KEY      R2 API-token Access Key ID.
#   MINIO_SECRET_KEY      R2 API-token Secret Access Key.
#   MINIO_BUCKET          R2 bucket name (keep == local so object keys match).
#   MINIO_PUBLIC_BASE_URL R2 bucket's PUBLIC custom domain, no trailing slash.
#                         Public read URLs become {base}/{key} — plain CDN URLs,
#                         no presigning (only accepted/public clips reach prod).
#                         MUST match the host allowed in app.yaml's CSP
#                         (mga-clips.myfreeapps.org) AND the domain the operator
#                         binds to the R2 bucket. Create the bucket BEFORE first
#                         boot (the lifespan bucket-check verifies, never creates).
#
# Local dev does NOT use this file — it uses backend/.env with standalone MinIO:
#   MINIO_ENDPOINT=localhost:9000  MINIO_SECURE=false  MINIO_PUBLIC_BASE_URL= (empty → presigned)
MINIO_ENDPOINT=<ACCOUNT_ID>.r2.cloudflarestorage.com
MINIO_SECURE=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=mygamingassistant-screenshots
MINIO_PUBLIC_BASE_URL=https://mga-clips.myfreeapps.org

# YouTube ingestion pipeline (PR 4+)
# Directory where yt-dlp downloads videos before ffmpeg frame extraction.
# Must be writable by the api container. The container tmpfs or a host-mounted
# volume are both fine; ensure >= INGESTION_DOWNLOAD_DIR_MAX_GB free space.
INGESTION_DOWNLOAD_DIR=/tmp/mga-ingestion
# Hard cap in GB — ingestion refuses to start if the path has less free space.
INGESTION_DOWNLOAD_DIR_MAX_GB=10
# Optional: bypass YouTube's "Sign in to confirm you're not a bot" challenge by
# borrowing cookies from an already-authenticated local browser session
# (yt-dlp's --cookies-from-browser equivalent). Valid: chrome, firefox, edge,
# safari, chromium, opera, brave, vivaldi, whale. Leave EMPTY in CI / fresh
# deploys where no local browser exists — that is the correct shape and the
# helper no-ops. Unknown values are logged at WARNING and no cookies are
# injected.
YOUTUBE_COOKIES_FROM_BROWSER=
# Path to a Netscape cookies.txt file. Takes precedence over
# YOUTUBE_COOKIES_FROM_BROWSER. Export from a logged-in YouTube session
# using a browser extension (e.g. "Get cookies.txt LOCALLY") and save to
# this path. Re-export when YouTube rotates the session (typically every
# few weeks). Leave blank to fall back to YOUTUBE_COOKIES_FROM_BROWSER.
# YOUTUBE_COOKIES_FILE=/srv/myfreeapps/secrets/youtube-cookies.txt

# APScheduler — background source sync cron (PR 6+).
# SCHEDULER_ENABLED=false disables automatic syncing entirely (manual-only via
# POST /api/scheduler/trigger/sync_all_sources). Useful for local dev / CI.
# In production, if sources exist and the scheduler fails to start, the boot
# guard fails loud.
SCHEDULER_ENABLED=true
# Interval between full source sync passes (all active sources, sequential).
# Default 6 hours is appropriate for daily-posted YouTube channels.
# Lower for faster iteration; higher to reduce yt-dlp API calls.
SOURCE_SYNC_INTERVAL_HOURS=6

# --- Cost-transparency / Support page (platform-wide, shared) ---
# NOTE: MyGamingAssistant serves from Cloudflare R2, not the shared MinIO, so it
# does NOT display the cost-transparency widget (its /support passes
# showTransparency=false). These vars are inert on MGA — included for parity with
# the other apps. Keep TRANSPARENCY_PRIMARY=false (MyBookkeeper is the primary
# writer). See platform_shared/services/transparency + project_mga_prod_storage_r2.
KOFI_VERIFICATION_TOKEN=
ANTHROPIC_ADMIN_API_KEY=
VPS_MONTHLY_COST_CENTS=0
DOMAIN_MONTHLY_COST_CENTS=0
TRANSPARENCY_PRIMARY=false
TRANSPARENCY_SHARED_BUCKET=myfreeapps-shared
