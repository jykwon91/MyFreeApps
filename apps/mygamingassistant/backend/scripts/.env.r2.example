# Cloudflare R2 credentials for publishing MyGamingAssistant lineup clips to prod.
#
# Copy this file to `.env.r2` IN THIS SAME DIRECTORY and fill in the real values
# from your Cloudflare R2 dashboard (the SAME S3 API token used for the prod
# MINIO_* vars on the VPS). `.env.r2` is gitignored — never commit it, never
# paste these values into chat.
#
# Consumed by ship-library.ps1 / publish_clips_to_r2.py to copy clip bytes from
# local MinIO into the prod R2 bucket. Format is KEY=VALUE, one per line.

# Bare account host — no https://, no path (e.g. abc123def.r2.cloudflarestorage.com)
R2_ENDPOINT=
# The R2 S3 API token pair (Object Read & Write, scoped to the bucket below)
R2_ACCESS_KEY=
R2_SECRET_KEY=
# Must match the prod MINIO_BUCKET so published keys line up with what the app serves
R2_BUCKET=mygamingassistant-screenshots
