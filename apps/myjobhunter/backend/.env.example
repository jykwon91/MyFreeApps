DATABASE_URL=postgresql+asyncpg://myjobhunter:password@localhost/myjobhunter
# database_url_sync is computed automatically from DATABASE_URL — do not set.
SECRET_KEY=change-me-to-a-64-hex-char-random-string
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# Unused in Phase 1 — required in Phase 2+
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CORS_ORIGINS=["http://localhost:5175"]
JWT_LIFETIME_SECONDS=1800
LOG_LEVEL=INFO

# HIBP compromised-password check — set to false in local dev / CI to skip
# the network call. Enabled by default in prod.
HIBP_ENABLED=true

# Cloudflare Turnstile CAPTCHA — wired on /auth/register and /auth/forgot-password.
# Empty values mean Turnstile is a no-op (dev / CI mode); set both in production.
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# Account-level login lockout (PR C3)
LOCKOUT_THRESHOLD=5
LOCKOUT_AUTORESET_HOURS=24

# Per-IP login throttle (PR C3) — same generic 429 body as account lockout
LOGIN_RATE_LIMIT_THRESHOLD=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Frontend URL — used to build verification email links (PR C4).
FRONTEND_URL=http://localhost:5174

# Email delivery — "console" (default) prints to stdout for dev/CI;
# "smtp" uses the SMTP_* vars below to actually send.
EMAIL_BACKEND=console
EMAIL_FROM_NAME=MyJobHunter
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Test-only — set to "1" to mount the /_test/* helper routes used by
# Playwright E2E tests (e.g. force-verify-email). Leave unset in prod.
# MYJOBHUNTER_ENABLE_TEST_HELPERS=1
