DATABASE_URL=postgresql+asyncpg://myjobhunter:password@localhost/myjobhunter
DATABASE_URL_SYNC=postgresql+psycopg2://myjobhunter:password@localhost/myjobhunter
SECRET_KEY=change-me-to-a-64-hex-char-random-string
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# Unused in Phase 1 — required in Phase 2+
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CORS_ORIGINS=["http://localhost:5175"]
JWT_LIFETIME_SECONDS=1800
LOG_LEVEL=INFO

# Frontend URL — used to build verification email links.
FRONTEND_URL=http://localhost:5174

# Email delivery — "console" (default) prints to stdout for dev/CI;
# "smtp" uses the SMTP_* vars below to actually send.
EMAIL_BACKEND=console
EMAIL_FROM_NAME=MyJobHunter
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Test-only — set to "1" to mount the /_test/* helper routes used by
# Playwright E2E tests (e.g. force-verify-email). Leave unset in prod.
# MYJOBHUNTER_ENABLE_TEST_HELPERS=1
