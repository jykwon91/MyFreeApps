# Docker environment template -- consumed by docker-compose.yml `env_file:` directive
# for the migrate and api services. Copy to backend/.env.docker and fill in values:
#   cp backend/.env.docker.example backend/.env.docker
#
# DATABASE_URL is set via docker-compose.yml `environment:` block -- do NOT set it here.
# DB_PASSWORD lives in apps/mypizzatracker/.env (same dir as docker-compose.yml) -- do NOT set it here.

# Deployment environment -- controls Sentry enforcement and the seed-user boot guard.
# Set to "production" in prod deployments; SENTRY_DSN and SEED_USER_* become REQUIRED.
# Leave as "development" or "test" for local/CI environments.
ENVIRONMENT=production

# Sentry DSN -- required when ENVIRONMENT=production. Boot fails loud if missing.
SENTRY_DSN=

SECRET_KEY=change-me-to-random-64-chars
ENCRYPTION_KEY=change-me-to-random-64-chars

# Single-user seed -- operator account.
# Both fields REQUIRED when ENVIRONMENT=production; boot guard fires if either is empty.
# Leave empty in dev/CI -- the seed is skipped with a WARNING log.
#
# To generate SEED_USER_PASSWORD_HASH:
#   python -c "from passlib.context import CryptContext; \
#     ctx = CryptContext(schemes=['bcrypt']); \
#     print(ctx.hash('your-password'))"
SEED_USER_EMAIL=
SEED_USER_PASSWORD_HASH=

# Frontend / CORS
FRONTEND_URL=https://mypizzatracker.myfreeapps.org
CORS_ORIGINS=["https://mypizzatracker.myfreeapps.org"]

# JWT
JWT_LIFETIME_SECONDS=1800
LOG_LEVEL=INFO

# HIBP compromised-password check -- leave true in prod
HIBP_ENABLED=true

# Cloudflare Turnstile CAPTCHA -- for the /forgot-password form.
# Registration is disabled (single-user app) so TURNSTILE_SITE_KEY
# is only needed for the forgot-password Turnstile widget. If Turnstile
# is not needed, leave these empty -- require_turnstile is a no-op when
# TURNSTILE_SECRET_KEY is unset.
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# Account-level login lockout
LOCKOUT_THRESHOLD=5
LOCKOUT_AUTORESET_HOURS=24

# Per-IP login throttle
LOGIN_RATE_LIMIT_THRESHOLD=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Email delivery
#
# Production MUST use EMAIL_BACKEND=smtp with valid SMTP_USER /
# SMTP_PASSWORD -- the platform_shared boot guard crashes the lifespan
# if EMAIL_BACKEND=console in non-development environments.
#
# For local dev / CI, set EMAIL_BACKEND=console and leave SMTP_* empty.
EMAIL_BACKEND=smtp
EMAIL_FROM_NAME=MyPizzaTracker
EMAIL_FROM_ADDRESS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# MinIO storage -- shared infra stack at infra/docker-compose.yml.
# Bucket mypizzatracker-uploads auto-creates on backend lifespan startup.
MINIO_ENDPOINT=myfreeapps-minio:9000
MINIO_PUBLIC_ENDPOINT=https://storage.myfreeapps.org
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=mypizzatracker-uploads
MINIO_SECURE=false
